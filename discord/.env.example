# Claude Discord Bridge — Environment Variables
# Copy this file to .env and fill in your values

# Bot name shown in Discord messages and notifications
BOT_NAME=MyBot

# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token

# Discord Server (Guild) ID
GUILD_ID=your_discord_server_id

# Comma-separated channel IDs the bot listens in
CHANNEL_IDS=channel_id_1,channel_id_2

# OpenAI API Key (for RAG embeddings)
OPENAI_API_KEY=your_openai_api_key

# ntfy push notifications (https://ntfy.sh)
NTFY_TOPIC=your_ntfy_topic_id
NTFY_SERVER=https://ntfy.sh

# Owner Discord User ID (right-click your name → Copy User ID with Developer Mode on)
# Only this user can run /run /schedule /remember /alert /stop /clear
OWNER_DISCORD_ID=your_discord_user_id

# Owner info (used in system prompt — no personal data in code)
OWNER_NAME=Owner
OWNER_TITLE=Owner
GITHUB_USERNAME=your_github_username
BLOG_URL=https://your-blog.example.com
PRIVATE_REPO_NAME=your-private-repo

# Calendar & Tasks (used in cron context files)
GMAIL_ACCOUNT=your@gmail.com
GOOGLE_TASKS_LIST_ID=your_tasks_list_id

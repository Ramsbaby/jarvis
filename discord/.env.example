# Jarvis — Environment Variables
# Copy this file to .env and fill in your values
# cp discord/.env.example discord/.env

# ============================================================
# ✅ REQUIRED — Bot won't start without these
# ============================================================

# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token

# Discord Server (Guild) ID (right-click server → Copy Server ID)
GUILD_ID=your_discord_server_id

# Comma-separated channel IDs the bot listens in
# Right-click a channel → Copy Channel ID (needs Developer Mode)
CHANNEL_IDS=channel_id_1,channel_id_2

# ============================================================
# ⚙️ RECOMMENDED — Most features work without these, but you'll want them
# ============================================================

# OpenAI API Key — enables vector search in RAG
# Without this, BM25 full-text search still works (no embeddings)
OPENAI_API_KEY=your_openai_api_key

# ntfy push notifications (https://ntfy.sh — free tier available)
NTFY_TOPIC=your_ntfy_topic_id
NTFY_SERVER=https://ntfy.sh

# Owner Discord User ID — gates privileged commands (/run /stop /clear etc.)
# Right-click your own name → Copy User ID (needs Developer Mode on)
OWNER_DISCORD_ID=your_discord_user_id

# ============================================================
# 📱 OPTIONAL — Personalization & integrations
# ============================================================

# Bot display name in messages and notifications
BOT_NAME=Jarvis

# Bot language: 'ko' (Korean, default) or 'en' (English)
BOT_LOCALE=en

# Owner info injected into system prompt (no personal data in code)
OWNER_NAME=Owner
OWNER_TITLE=Owner
GITHUB_USERNAME=your_github_username
BLOG_URL=https://your-blog.example.com
PRIVATE_REPO_NAME=your-private-repo

# Jina AI Reranker — cross-encoder reranking improves RAG precision
# Free tier: 1M tokens/month at https://jina.ai
JINA_API_KEY=your_jina_api_key

# Google Calendar & Tasks (used in cron context files)
GOOGLE_ACCOUNT=your@gmail.com
GOOGLE_TASKS_LIST_ID=your_tasks_list_id

# Comma-separated Discord channel IDs for family/personal notifications (optional)
FAMILY_CHANNEL_IDS=
# Family member name for personalized prompts (optional)
FAMILY_MEMBER_NAME=

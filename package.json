{
  "name": "jarvis-privacy-guard",
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "git config core.hooksPath .githooks",
    "privacy:scan": "node scripts/privacy/scan.mjs --all",
    "privacy:scan-staged": "node scripts/privacy/scan.mjs --staged",
    "guard:validate": "node .jarvis/lib/guards/guard-pipeline.mjs"
  }
}

  "monitoring_and_alerts": {
    "enabled": true,
    "alert_rules": [
      {
        "name": "gemini_daily_cost_spike",
        "condition": "daily_gemini_cost > $0.20",
        "action": "discord_alert",
        "channel": "jarvis-system",
        "severity": "warning"
      },
      {
        "name": "gemini_fallback_rate_high",
        "condition": "fallback_rate > 10%",
        "action": "discord_alert",
        "channel": "jarvis-system",
        "severity": "critical",
        "auto_disable": true
      },
      {
        "name": "gemini_api_unavailable",
        "condition": "consecutive_failures > 3",
        "action": "disable_routing",
        "alert": "discord",
        "rationale": "자동 폴백 후 Gemini 장애 지속 시 라우팅 비활성화"
      }
    ]

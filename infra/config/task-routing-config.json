  "routing_rules": {
    "rules": [
      {
        "rule_id": "non_core_to_gemini",
        "enabled": true,
        "priority": 10,
        "description": "비핵심 태스크를 Gemini 3.5 Flash로 라우팅",
        "task_ids": [
          "news-briefing",
          "daily-summary",
          "system-health",
          "memory-cleanup",
          "log-analysis",
          "github-monitor"
        ],
        "source_model": "claude-haiku-4-5-20251001",
        "target_model": "gemini-3-5-flash",
        "estimated_savings_percent": 80,
        "rationale": "단순 요약/분류 작업으로 Gemini 3.5 Flash의 1M 컨텍스트 활용 가능. 응답 품질 저하 최소.",
        "cost_target_per_1m_input": 1.50,
        "cost_target_per_1m_output": 9.00
      },
      {
        "rule_id": "large_doc_to_gemini_2_flash",
        "enabled": false,
        "priority": 20,
        "description": "100K+ 토큰 입력 문서를 Gemini 2.0 Flash로 라우팅 (향후 활성화)",
        "task_condition": {
          "inputTokens": {">": 100000}
        },
        "target_model": "gemini-2-flash",
        "rationale": "1M 컨텍스트 필수 처리. 비용 추가 절감 가능.",
        "cost_target_per_1m_input": 0.075,
        "cost_target_per_1m_output": 0.30
      }
    ]
  },
  "core_task_protection": {
    "enabled": true,
    "protected_task_ids": [
      "council",
      "reasoning",
      "morning-standup",
      "macro-briefing",
      "career-strategy",
      "market-analysis"
    ],
    "protected_keywords": [
      "council",
      "reasoning",
      "decision",
      "analysis",
      "strategy",
      "planning"
    ],
    "min_model_tier": "sonnet",
    "force_claude_models": [
      "claude-sonnet-4-6",
      "claude-opus-4-7"
    ],
    "rationale": "핵심 의사결정/분석 태스크는 Claude 강제로 품질 보장"
  },
  "fallback_policy": {
    "enabled": true,
    "on_gemini_api_error": "fallback_to_source_model",
    "on_gemini_timeout": "fallback_to_source_model",
    "on_rate_limit": "fallback_to_deepseek",
    "max_retries_before_fallback": 2,
    "retry_backoff_ms": [2000, 4000],
    "timeout_seconds": 60,
    "rationale": "Gemini 장애 시 자동으로 원본 모델(Claude) 또는 DeepSeek로 폴백하여 안정성 확보"
  },
  "cost_tracking": {
    "enabled": true,
    "log_file": "${BOT_HOME:-${HOME}/jarvis/runtime}/logs/routing-metrics.jsonl",
    "cost_summary_file": "${BOT_HOME:-${HOME}/jarvis/runtime}/logs/cost-summary.jsonl",
    "sample_rate": 1.0,
    "track_fields": [
      "ts",
      "task_id",
      "source_model",
      "target_model",
      "input_tokens",
      "output_tokens",
      "cost_source",
      "cost_target",
      "cost_saved",
      "savings_percent",
      "api_provider",
      "routing_reason",
      "success",
      "latency_ms",
      "error"
    ],
    "rationale": "라우팅 효과 투명성 확보 및 비용 절감 실시간 추적"
  },

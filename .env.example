# Jarvis .env 설정 파일
# 복사 후 값 채우기: cp .env.example .env

# ===== 필수 =====
DISCORD_TOKEN=your_discord_bot_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===== Discord 서버 설정 =====
GUILD_ID=your_discord_guild_id           # 슬래시 커맨드 등록 대상 서버 ID
CHANNEL_IDS=channel_id1,channel_id2     # 봇이 응답할 채널 ID (쉼표 구분)
QUIET_CHANNEL_IDS=                       # 재시작 알림 제외 채널 ID (쉼표 구분, 선택)

# ===== Discord 사용자 설정 =====
OWNER_DISCORD_ID=your_discord_user_id   # 오너 Discord 사용자 ID (권한 체크)
BORAM_DISCORD_ID=                        # 아내 Discord 사용자 ID (선택)

# ===== 봇 페르소나 설정 =====
BOT_NAME=Jarvis                          # 봇 이름 (시스템 프롬프트·로그에 사용)
BOT_LOCALE=ko                            # 응답 로케일 (ko / en)
OWNER_NAME=Owner                         # 오너 이름 (시스템 프롬프트에 사용)
OWNER_TITLE=Owner                        # 오너 직함 (시스템 프롬프트에 사용)
GITHUB_USERNAME=                         # GitHub 사용자명 (Owner Context에 표시)

# ===== 알림 채널 설정 =====
OWNER_ALERT_CHANNEL_ID=                  # 오너 전용 알림 채널 ID (선택)

# ===== 알림 서비스 (선택) =====
NTFY_SERVER=https://ntfy.sh             # ntfy 서버 URL
NTFY_TOPIC=                              # ntfy 토픽명 (비어 있으면 알림 비활성화)

# ===== 외부 서비스 (선택) =====
OPENAI_API_KEY=                          # OpenAI API 키 (Discord 음성 메시지 Whisper 변환용)
CLAUDE_BINARY=                           # claude 실행 파일 경로 (기본: ~/.local/bin/claude)

# ===== 기타 =====
JARVIS_HOME=/jarvis          # Docker 기본값. 로컬 실행 시 제거해도 됨
NODE_ENV=production

# Google Calendar (선택)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Discord 채널 IDs (레거시 — CHANNEL_IDS로 대체됨)
DISCORD_CHANNEL_JARVIS_CEO=
DISCORD_CHANNEL_JARVIS_DEV=
